# Server Configuration
PORT=3000
ADMIN_USER=admin
ADMIN_PASS=admin

# JWT Secret Key for Session Tokens
JWT_SECRET=your_random_jwt_secret_key_here

# Device Registration Secret Token
REGISTER_SECRET=default-register-secret

# VPS Deployment Settings (for npx tsx deploy.ts)
VPS_HOST=your_vps_ip_address
VPS_PORT=22
VPS_USER=root
VPS_PASS=your_vps_ssh_password
